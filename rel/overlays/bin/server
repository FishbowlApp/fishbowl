#!/bin/sh
cd -P -- "$(dirname -- "$0")"

echo "Current user: $(whoami)"

# If USE_INTEGRATED_TAILSCALE is set, init tailscale
if [ -n "${USE_INTEGRATED_TAILSCALE}" ]; then
  echo "USE_INTEGRATED_TAILSCALE is set (Fly.io), initializing Tailscale"

  tailscaled --state=/var/lib/tailscale/tailscaled.state \
  --socket=/var/run/tailscale/tailscaled.sock --no-logs-no-support > /dev/null 2>&1 &
  sleep 2

  tailscale up --auth-key=${TAILSCALE_AUTHKEY} --hostname=octo-${FLY_PROCESS_GROUP}-${FLY_REGION}
else
  echo "USE_INTEGRATED_TAILSCALE is not set; assuming Tailscale is running in a sidecar"

  secrets_ip=$(echo "$OP_CONNECT_HOST" | sed -E 's#http://([^:/]+):.*#\1#')
  echo "Ensuring Tailscale is up and secrets service is reachable at [$secrets_ip]..."

  until ping -c 1 -W 1 "$secrets_ip" >/dev/null 2>&1 && \
    ip -j address show dev tailscale0 2>/dev/null | \
    jq -e -r '.[0].addr_info[]? | select(.family=="inet") | .local' | \
    grep -qE '^[0-9]+\.[0-9]+\.[0-9]+\.[0-9]+$'
  do
    echo "Waiting for [$secrets_ip] to respond..."
    sleep 1
  done
fi

echo "Switching to user: nobody"

echo "1Password host: ${OP_CONNECT_HOST}"
export OP_CONFIG_DIR="/tmp/.op"

# PHX_SERVER=true exec ./octocon start
exec su -s /bin/sh nobody -c 'PHX_SERVER=true op run --no-masking --env-file="/app/etc/.env" -- ./octocon start'
